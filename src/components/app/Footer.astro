---
import AppLogo from "./Logo.astro";
import { Icon } from "astro-icon/components";
import config from "@util/themeConfig";
import { getLocalizedThemeConfig } from "@util/localizedThemeConfig";
import { getLangFromUrl, getLocalizedFooterNavigation } from "@util/i18n";

const lang = getLangFromUrl(new URL(Astro.request.url));
const localizedConfig = getLocalizedThemeConfig(lang);
const socials = Object.values(localizedConfig.footer.socials);
const socialNames = Object.keys(localizedConfig.footer.socials);

// Get base navigation
const baseNavigation = [
  {
    title: "Directory",
    links: [
      { title: "Submit", link: "/submit" },
      { title: "Advertise", link: "/advertise" },
    ],
  },
  {
    title: "Categories",
    links: localizedConfig.directoryData.tags
      ?.filter((e: any) => e && e.name)
      .map((e: any) => ({
        title: e.name,
        link: `/tags/${e.key}`,
      }))
      .slice(0, 4),
  },
  {
    title: "Legal",
    links: [
      { title: "Privacy Policy", link: "/legal/terms-of-service" },
      { title: "Terms of Service", link: "/legal/privacy-policy" },
    ],
  },
];

// Get localized navigation
const navigation = getLocalizedFooterNavigation(lang, baseNavigation);
---

<footer
  class="border-t border-gray-200 dark:border-gray-600 font-display"
  aria-labelledby="footer-heading"
>
  <h2 id="footer-heading" class="sr-only">Footer</h2>
  <div class="mx-auto max-w-7xl px-6 pb-8 pt-16 sm:pt-24 lg:px-8 lg:pt-32">
    <div class="xl:grid xl:grid-cols-3 xl:gap-8">
      <div class="space-y-8">
        <AppLogo />
        <div class="flex space-x-6">
          {
            socials.map((item, index) => (
              <a href={(item as any)?.link} class="text-gray-400 hover:text-gray-500">
                <span class="sr-only">{item}</span>
                <Icon
                  name={
                    config.ui.icons[
                      socialNames[index] as keyof typeof config.ui.icons
                    ]
                  }
                  class="h-6 w-6"
                  aria-hidden="true"
                />
              </a>
            ))
          }
        </div>
      </div>
      <div class="mt-16 grid grid-cols-3 gap-8 xl:col-span-2 xl:mt-0 xl:justify-items-end">
        {
          navigation.map((section) => (
            <div>
              <h3 class="text-sm font-semibold text-gray-400 tracking-wider uppercase">
                {section.title}
              </h3>
              <ul role="list" class="mt-6 space-y-4">
                {section.links.map((item) => (
                  <li>
                    <a
                      href={item.link}
                      class="text-sm leading-6 text-gray-600 dark:text-gray-300 hover:dark:text-gray-400 hover:text-gray-900"
                    >
                      {item.title}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </div>
    <div
      class="mt-16 border-t border-gray-900/10 dark:border-gray-600 pt-8 sm:mt-20 lg:mt-24"
    >
      <p class="text-xs leading-5 text-gray-500">
        &copy; {new Date().getFullYear()}
        {localizedConfig.general.title} All rights reserved.
      </p>
    </div>
  </div>
</footer>
